# ============================================================
# KOL Quest — API Keys Configuration
# Copy this file to .env and fill in your keys.
# All keys are optional — fetches skip gracefully if missing.
# ============================================================

# ── SOLANA ──────────────────────────────────────────────────

# Helius — best Solana wallet/token indexer. Free tier: 10k credits/day
# Sign up: https://www.helius.dev/
HELIUS_API_KEY=

# Birdeye — Solana token + wallet analytics. Free tier available.
# Sign up: https://docs.birdeye.so/
BIRDEYE_API_KEY=

# Solscan Pro — enhanced Solana explorer API. Free tier available.
# Sign up: https://pro-api.solscan.io/
SOLSCAN_API_KEY=

# ── MULTI-CHAIN WALLET APIs ──────────────────────────────────

# Moralis — EVM + Solana wallet data. Free tier: 40k CU/day
# Sign up: https://moralis.io/
MORALIS_API_KEY=

# Covalent (GoldRush) — 200+ chain wallet API. Free tier available.
# Sign up: https://www.covalenthq.com/
COVALENT_API_KEY=

# Tatum — 90+ chain unified API. Free tier: 10 req/sec
# Sign up: https://tatum.io/
TATUM_API_KEY=

# Chainbase — multi-chain wallet + token indexer. Free tier available.
# Sign up: https://chainbase.com/
CHAINBASE_API_KEY=

# DeBank — best EVM DeFi position tracker. Free: 100k API units.
# Sign up: https://cloud.debank.com/
DEBANK_API_KEY=

# Zerion — EVM portfolio + transaction history. Free partner access.
# Sign up: https://developers.zerion.io/
ZERION_API_KEY=

# ── EVM EXPLORER APIs (Etherscan family) ─────────────────────
# Each requires a separate free API key. Sign up at each explorer.

# Etherscan — https://etherscan.io/apidashboard
ETHERSCAN_API_KEY=

# BscScan — https://bscscan.com/apidashboard (BSC)
BSCSCAN_API_KEY=

# BaseScan — https://basescan.org/apidashboard (Base)
BASESCAN_API_KEY=

# ArbScan — https://arbiscan.io/apidashboard (Arbitrum)
ARBISCAN_API_KEY=

# PolygonScan — https://polygonscan.com/apidashboard (Polygon)
POLYGONSCAN_API_KEY=

# OptimismScan — https://optimistic.etherscan.io/apidashboard (Optimism)
OPTIMISMSCAN_API_KEY=

# ── ALCHEMY ──────────────────────────────────────────────────
# One key works per network. Free tier: 300M CU/month per app.
# Sign up: https://www.alchemy.com/
# Can reuse one key across multiple if created on same app.
ALCHEMY_ETH_KEY=
ALCHEMY_BASE_KEY=
ALCHEMY_ARB_KEY=
ALCHEMY_POLYGON_KEY=
ALCHEMY_OPT_KEY=
ALCHEMY_SOL_KEY=

# ── ANALYTICS / QUERY ENGINES ────────────────────────────────

# Dune Analytics — SQL + Echo API for smart money. Free: 1000 credits/month.
# Sign up: https://dune.com/
DUNE_API_KEY=

# Flipside Crypto — SQL analytics. Free tier available.
# Sign up: https://flipsidecrypto.xyz/
FLIPSIDE_API_KEY=

# Bitquery — GraphQL blockchain data. Free tier: 10k points/month.
# Sign up: https://bitquery.io/
BITQUERY_API_KEY=

# ── PRIORITY RECOMMENDATION ──────────────────────────────────
# Start with these for the best ROI — all free:
#   1. HELIUS_API_KEY       (Solana — most complete wallet data)
#   2. BIRDEYE_API_KEY      (Solana token analytics)
#   3. MORALIS_API_KEY      (EVM — easiest multi-chain wallet data)
#   4. COVALENT_API_KEY     (EVM — best token transfer indexing)
#   5. ETHERSCAN_API_KEY    (ETH — ground truth tx data)
#   6. BSCSCAN_API_KEY      (BSC — ground truth tx data)
#   7. DEBANK_API_KEY       (EVM DeFi positions — most complete)
#   8. DUNE_API_KEY         (smart money SQL queries)
